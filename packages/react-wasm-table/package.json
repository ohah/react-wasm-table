{
  "name": "@ohah/react-wasm-table",
  "version": "0.1.0",
  "description": "High-performance React table component powered by Rust/WASM",
  "keywords": [
    "high-performance",
    "react",
    "table",
    "virtual-scroll",
    "wasm"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "wasm"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./wasm": {
      "types": "./dist/wasm.d.ts",
      "development": "./src/entries/wasm.ts",
      "import": "./dist/wasm.js"
    },
    "./sorting": {
      "types": "./dist/sorting.d.ts",
      "development": "./src/entries/sorting.ts",
      "import": "./dist/sorting.js"
    },
    "./filtering": {
      "types": "./dist/filtering.d.ts",
      "development": "./src/entries/filtering.ts",
      "import": "./dist/filtering.js"
    },
    "./grouping": {
      "types": "./dist/grouping.d.ts",
      "development": "./src/entries/grouping.ts",
      "import": "./dist/grouping.js"
    },
    "./selection": {
      "types": "./dist/selection.d.ts",
      "development": "./src/entries/selection.ts",
      "import": "./dist/selection.js"
    },
    "./clipboard": {
      "types": "./dist/clipboard.d.ts",
      "development": "./src/entries/clipboard.ts",
      "import": "./dist/clipboard.js"
    },
    "./renderers": {
      "types": "./dist/renderers.d.ts",
      "development": "./src/entries/renderers.ts",
      "import": "./dist/renderers.js"
    }
  },
  "scripts": {
    "build": "bunx tsdown",
    "dev": "bunx tsdown --watch"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsdown": "0.20.3",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  }
}
